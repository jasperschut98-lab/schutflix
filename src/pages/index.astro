---
import ServiceCard from '../components/ServiceCard.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="nl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Schutflix | Home</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=1" />
		<meta name="robots" content="noindex, nofollow" />
	</head>
	<body>
		<!-- Intro Animation Splash Screen -->
		<div id="splash-screen">
			<img src="/logo.png" alt="Schutflix Logo" class="intro-logo-img" id="intro-logo" />
		</div>

		<!-- Welcome Popup -->
		<div id="welcome-popup" class="popup-overlay" style="display:none;">
			<div class="popup-card">
				<button class="popup-close" id="welcome-close" aria-label="Sluiten">✕</button>
				<h2>Welkom bij Schutflix! 👋</h2>
				<p>Schutflix is ons eigen media-platform. Hier kun je films en series kijken, audioboeken luisteren en meer – allemaal vanuit één plek.</p>
				<p>Eerste keer hier? Bekijk de <a href="/info"><strong>Info & hulp</strong></a> pagina voor een korte uitleg en stap-voor-stap handleidingen.</p>
				<button class="popup-btn" id="welcome-dismiss">Begrepen, aan de slag!</button>
			</div>
		</div>

		<!-- Contact Modal -->
		<div id="contact-modal" class="popup-overlay" style="display:none;">
			<div class="popup-card contact-card">
				<button class="popup-close" id="contact-close" aria-label="Sluiten">✕</button>
				<h2>📬 Neem contact op</h2>
				<p>Heb je een vraag, probleem, of suggestie? Stuur een bericht!</p>
				<form id="contact-form">
					<input type="text" name="name" placeholder="Je naam" required />
					<input type="email" name="email" placeholder="Je e-mailadres" required />
					<textarea name="message" placeholder="Je bericht..." rows="4" required></textarea>
					<button type="submit" class="popup-btn">Verstuur bericht</button>
				</form>
				<p id="contact-success" class="contact-success" style="display:none;">✅ Je bericht is verzonden! We nemen zo snel mogelijk contact met je op.</p>
			</div>
		</div>

		<div class="container">
			<header>
				<div class="logo-container">
					<img src="/logo.png" alt="Schutflix Logo" class="hero-logo" id="hero-logo" />
				</div>
			</header>

			<main>
				<div class="services-grid">
					<ServiceCard 
						title="Jellyfin" 
						href="http://watch.schutflix.nl" 
						icon="https://cdn.simpleicons.org/jellyfin"
						description="Kijk films en series – net als Netflix, maar dan van ons."
					/>
					<ServiceCard 
						title="Audiobookshelf" 
						href="http://books.schutflix.nl" 
						icon="https://cdn.simpleicons.org/audiobookshelf"
						description="Luister audioboeken en podcasts via de app of in je browser."
					/>
					<ServiceCard 
						title="Immich" 
						href="http://fotos.schutflix.nl" 
						icon="https://cdn.simpleicons.org/immich"
						description="Bewaar, beheer en deel al je foto's en video's veilig in je eigen cloud."
					/>
					<ServiceCard 
						title="Nextcloud" 
						href="http://cloud.schutflix.nl" 
						icon="https://cdn.simpleicons.org/nextcloud"
						description="Jouw veilige plek voor het opslaan en delen van bestanden."
					/>
					<ServiceCard 
						title="Seerr" 
						href="http://request.schutflix.nl" 
						icon="https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/svg/overseerr.svg"
						description="Mis je een film of serie? Vraag 'm hier aan!"
					/>
					<ServiceCard 
						title="Info & hulp" 
						href="/info" 
						icon=""
						description="Handleidingen, veelgestelde vragen en hulp."
					/>
					<a href="#" class="service-card contact-trigger" id="contact-btn">
						<div class="icon-container emoji-icon"><span>📬</span></div>
						<div class="content">
							<h3>Contact</h3>
							<p>Stuur een bericht of stel een vraag.</p>
						</div>
					</a>
				</div>

				<details class="dev-section">
					<summary class="section-title">
						<span>Developer Tools</span>
					</summary>
					<div class="services-grid mini">
						<ServiceCard 
							title="Sonarr" 
							href="http://sonarr.schutflix.nl" 
							icon="https://cdn.simpleicons.org/sonarr"
							description="Automatiseer en beheer je TV-series collectie."
						/>
						<ServiceCard 
							title="Radarr" 
							href="http://radarr.schutflix.nl" 
							icon="https://cdn.simpleicons.org/radarr"
							description="Vind en download automatisch je favoriete films."
						/>
						<ServiceCard 
							title="Prowlarr" 
							href="http://prowlarr.schutflix.nl" 
							icon="https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/svg/prowlarr.svg"
							description="Beheer al je media indexers op één plek."
						/>
						<ServiceCard 
							title="Tracearr" 
							href="http://stats.schutflix.nl" 
							icon="https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/svg/tracearr.svg"
							description="Monitor en traceer server- en media statistieken."
						/>
						<ServiceCard 
							title="qBittorrent" 
							href="http://qbit.schutflix.nl" 
							icon="https://cdn.simpleicons.org/qbittorrent"
							description="Je centrale beheer voor media downloads."
						/>
					</div>
				</details>
			</main>
		</div>

		<script>
			// Remove splash screen after animation
			setTimeout(() => {
				const splash = document.getElementById('splash-screen');
				if (splash) splash.style.display = 'none';
			}, 5000);

			// Welcome popup - show after intro, only once per session
			setTimeout(() => {
				if (!localStorage.getItem('welcomeDismissed')) {
					const popup = document.getElementById('welcome-popup');
					if (popup) popup.style.display = 'flex';
				}
			}, 4500);

			document.getElementById('welcome-close')?.addEventListener('click', () => {
				document.getElementById('welcome-popup').style.display = 'none';
				localStorage.setItem('welcomeDismissed', 'true');
			});
			document.getElementById('welcome-dismiss')?.addEventListener('click', () => {
				document.getElementById('welcome-popup').style.display = 'none';
				localStorage.setItem('welcomeDismissed', 'true');
			});

			// Contact modal
			document.getElementById('contact-btn')?.addEventListener('click', (e) => {
				e.preventDefault();
				document.getElementById('contact-modal').style.display = 'flex';
			});
			document.getElementById('contact-close')?.addEventListener('click', () => {
				document.getElementById('contact-modal').style.display = 'none';
			});

			// Close modals on overlay click
			document.querySelectorAll('.popup-overlay').forEach(overlay => {
				overlay.addEventListener('click', (e) => {
					if (e.target === overlay) {
						overlay.style.display = 'none';
						if (overlay.id === 'welcome-popup') {
							localStorage.setItem('welcomeDismissed', 'true');
						}
					}
				});
			});

			// Contact form submission
			document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const form = e.target;
				const data = new FormData(form);
				
				try {
					await fetch('https://formsubmit.co/ajax/schut98@outlook.com', {
						method: 'POST',
						body: data
					});
					form.style.display = 'none';
					document.getElementById('contact-success').style.display = 'block';
				} catch (err) {
					alert('Er ging iets mis. Probeer het later opnieuw.');
				}
			});
		</script>
	</body>
</html>
