---
interface Props {
	title: string;
	href: string;
	icon: string;
	description?: string;
}

const { title, href, icon, description } = Astro.props;
---

<a href={href} class="service-card" target="_blank" rel="noopener noreferrer">
	<div class="icon-container">
		<img src={icon} alt={`${title} logo`} class="service-icon" />
	</div>
	<div class="content">
		<h3>{title}</h3>
		{description && <p>{description}</p>}
	</div>
</a>

<style>
	.service-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 2.5rem 1.5rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 12px;
		text-decoration: none;
		color: white;
		transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
		backdrop-filter: blur(12px);
		text-align: center;
		height: 100%;
	}

	.service-card:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.2);
		transform: translateY(-8px) scale(1.02);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
	}

	.icon-container {
		width: 64px;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 1.5rem;
	}

	.service-icon {
		width: 100%;
		height: 100%;
		object-fit: contain;
		filter: drop-shadow(0 0 8px rgba(0,0,0,0.3));
	}

	.content h3 {
		font-family: 'Outfit', sans-serif;
		font-size: 1.25rem;
		font-weight: 600;
		margin: 0 0 0.5rem;
		letter-spacing: -0.01em;
	}

	.content p {
		font-size: 0.875rem;
		color: rgba(255, 255, 255, 0.5);
		margin: 0;
		line-height: 1.5;
	}
</style>
